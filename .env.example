# ---------------------------------------------------------------------------
# Anticipation Report configuration
# Copy this file to ".env" and fill in your keys, then run `npm run fetch`.
# Without keys, the app runs on the built-in SAMPLE dataset so you can see it
# working immediately. With keys, it pulls live data from Trakt + TMDB.
# ---------------------------------------------------------------------------

# Trakt API "Client ID" — provides the anticipated-shows ranking.
# Get one free: https://trakt.tv/oauth/applications -> "New Application"
#   - Name: anything (e.g. "My Anticipation Report")
#   - Redirect uri: urn:ietf:wg:oauth:2.0:oob
#   After creating, copy the "Client ID" value below.
TRAKT_CLIENT_ID=

# TMDB API key — provides posters, backdrops, networks and air dates.
# Get one free: https://www.themoviedb.org/settings/api  (request an "API Key (v3 auth)")
TMDB_API_KEY=

# How many shows to include in the report (Trakt max per page is 100).
REPORT_LIMIT=25

# Port for the dashboard web server.
PORT=3000

# Cron schedule for automatic refreshes (default: every Monday 09:00).
# Format: minute hour day-of-month month day-of-week. See https://crontab.guru
# Set to "off" to disable in-process scheduling (e.g. if you use the GitHub Action).
REFRESH_CRON=0 9 * * 1
